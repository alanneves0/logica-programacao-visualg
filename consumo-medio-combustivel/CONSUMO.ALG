Algoritmo "Consumo"

Var

   distancia, combustivelGasto, media : real
   

Inicio

   escreva ("Distancia percorrida: ")
   leia (distancia)
   escreva ("Combustível gasto: ")
   leia (combustivelGasto)
   
     media <- distancia / combustivelGasto
     
   escreva ("Consumo medio = ",media:4:3)

Fimalgoritmo